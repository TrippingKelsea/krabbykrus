#!/bin/sh
# post-commit hook: tag every commit with its workspace version (v0.x.y)

CARGO_TOML="$(git rev-parse --show-toplevel)/Cargo.toml"

version=$(awk '
    /^\[workspace\.package\]/ { in_section=1; next }
    in_section && /^\[/ { in_section=0 }
    in_section && /^version[[:space:]]*=/ {
        match($0, /"([0-9]+\.[0-9]+\.[0-9]+)"/, arr)
        print arr[1]
        exit
    }
' "$CARGO_TOML")

if [ -z "$version" ]; then
    echo "post-commit: could not read version from Cargo.toml" >&2
    exit 0
fi

tag="v${version}"

# Only create the tag if it doesn't already exist
if ! git rev-parse "$tag" >/dev/null 2>&1; then
    git tag "$tag"
    echo "post-commit: tagged ${tag}"
fi
